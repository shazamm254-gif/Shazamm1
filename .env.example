# --- Core ---
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Data ---
# If DATABASE_URL is set, the PostgreSQL adapter is used (production).
# If unset, a zero-setup file-backed adapter is used (local dev), stored at:
DATA_FILE=".data/db.json"
# PostgreSQL connection string (enables the Postgres adapter):
# DATABASE_URL="postgresql://user:pass@host:5432/proposalforge"
# DATABASE_SSL="true"        # set for managed Postgres that requires SSL
# DATABASE_POOL_MAX="10"     # optional pool size

# --- AI ---
# Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# --- Email (transactional; Resend) ---
# When both are set, real emails are sent; otherwise emails are logged to the
# server console so flows remain testable in dev.
RESEND_API_KEY=""
EMAIL_FROM="ProposalForge <noreply@yourdomain.com>"

# --- Billing (optional; features are gated on these being present) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_PRO=""

# Public base URL (used for share links and Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
