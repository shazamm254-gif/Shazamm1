# Copy this file to `.env` and fill in your keys, then:  source .env
# (or use a tool like direnv / python-dotenv). Never commit your real .env —
# it's already in .gitignore.

# --- Required for the analytics + metadata tools ---
# Get a key at https://console.cloud.google.com/ -> enable "YouTube Data API v3"
# -> Credentials -> Create API key. This is a read-only public-data key; it does
# NOT let anyone post to or change your channel.
export YOUTUBE_API_KEY="your-youtube-data-api-key"

# Your channel handle (with or without the @) or channel ID.
export YOUTUBE_CHANNEL="@CosmicDread"

# --- Optional: only for the --use-claude AI features ---
# Get a key at https://console.anthropic.com/
export ANTHROPIC_API_KEY="your-anthropic-api-key"

# --- Optional: only for tools/generate_voiceover.py ---
# Free, self-hosted, OpenAI-compatible text-to-speech server. Run it with:
#   docker run -d -p 5050:5050 travisvn/openai-edge-tts:latest
export TTS_API_URL="http://localhost:5050"
# Only needed if the container was started with REQUIRE_API_KEY=True.
export TTS_API_KEY=""
# OpenAI-style voice name (alloy, echo, fable, onyx, nova, shimmer) or any
# edge-tts voice. onyx/fable read as deep + documentary, matching the channel.
export TTS_VOICE="onyx"
