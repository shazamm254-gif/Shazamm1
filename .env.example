# --- Core ---
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Where the file-backed data store lives (the committed MVP adapter).
# In production, replace src/lib/db.ts with a Postgres-backed implementation
# (the typed `db` interface is the swap point) and point your driver here.
DATA_FILE=".data/db.json"

# --- AI ---
# Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# --- Billing (optional; features are gated on these being present) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_PRO=""

# Public base URL (used for share links and Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
