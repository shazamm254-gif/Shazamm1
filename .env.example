# Copy this file to `.env` (same folder as package.json) and fill in your keys.
# No quotes, no spaces around the `=`. The .env file is gitignored — never commit it.
# These are read ONLY by the Express backend; they are never sent to the browser.

# YouTube Data API v3 key (Google Cloud Console → enable "YouTube Data API v3"
# → Credentials → Create API key). Read-only public data.
YOUTUBE_API_KEY=

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OPTIONAL: route all "Claude" calls through OpenRouter (OpenAI-compatible
# gateway) instead of Anthropic. Useful if you have no Anthropic credits —
# OpenRouter offers free models. If OPENROUTER_API_KEY is set it takes priority
# over ANTHROPIC_API_KEY. OPENROUTER_MODEL is optional (default: a free model).
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# ElevenLabs API key (Stage 4 voiceover) — https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Leonardo.ai API key (Stage 5 visuals) — https://leonardo.ai/
LEONARDO_API_KEY=

# Port the backend listens on (frontend proxies /api/* here).
PORT=8787

# --- Optional: only used by the legacy Python toolkit in docs/SHORTS_TOOLKIT.md ---
# (uses `source .env`, so it needs the `export` form). Not needed for the web app.
# export YOUTUBE_CHANNEL="@CosmicDread"
